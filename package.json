{
    "name": "setup-server",
    "version": "1.0.0",
    "description": "",
    "main": "server.ts",
    "scripts": {
        "dist": "npx tsc",
        "build": "npx tsc",
        "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts --exec tsx src/server.ts",
        "start": "cross-env NODE_ENV=production node dist/server.js",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "prepare": "husky"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "lint-staged": {
        "*.{ts}": [
            "npm run lint:fix",
            "npm run format:fix"
        ]
    },
    "type": "module",
    "devDependencies": {
        "@commitlint/cli": "^20.5.2",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@types/eslint__js": "^8.42.3",
        "@types/node": "^25.6.2",
        "dotenv": "^17.4.2",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.3",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "dependencies": {
        "cross-env": "^10.1.0",
        "dotenv-flow": "^4.1.0"
    }
}

